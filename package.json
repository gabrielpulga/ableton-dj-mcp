{
  "name": "ableton-dj-mcp",
  "version": "1.6.0",
  "description": "MCP server for AI-assisted electronic music production in Ableton Live",
  "homepage": "https://github.com/gabrielpulga/ableton-dj-mcp",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gabrielpulga/ableton-dj-mcp.git"
  },
  "type": "module",
  "imports": {
    "#src/*": "./src/*"
  },
  "author": "Gabriel Pulga",
  "license": "GPL-3.0-or-later",
  "engines": {
    "node": ">=24"
  },
  "keywords": [
    "music",
    "ai",
    "mcp",
    "ableton",
    "electronic-music",
    "music-production",
    "ableton-live",
    "max-for-live",
    "indie-dance",
    "techno",
    "house-music",
    "music-theory"
  ],
  "scripts": {
    "dev": "npm run parser:build && rollup -c config/rollup.config.mjs -w",
    "build": "npm run parser:build && rollup -c config/rollup.config.mjs",
    "test": "npm run test:setup && vitest run --reporter=./config/vitest-minimal-reporter.mjs --silent=true",
    "test:watch": "npm run test:setup && vitest --reporter=dot --silent=true",
    "test:coverage": "npm run test:setup && vitest run --coverage --reporter=./config/vitest-minimal-reporter.mjs --silent=true",
    "test:verbose": "npm run test:setup && vitest run --reporter=default --silent=true",
    "test:setup": "npm run parser:build",
    "coverage": "npm run test:coverage",
    "check": "npm run lint --silent && npm run typecheck --silent && npm run format:check --silent && npm run duplication --silent && npm run test:coverage --silent",
    "fix": "npm run lint:fix && npm run format",
    "parser:build": "peggy --format es --output src/notation/barbeat/parser/generated-barbeat-parser.js src/notation/barbeat/parser/barbeat-grammar.peggy && peggy --format es --output src/notation/transform/parser/generated-transform-parser.js src/notation/transform/parser/transform-grammar.peggy",
    "parser:watch": "chokidar 'src/**/*.peggy' -c 'npm run parser:build'",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "echo 'Linting...' && eslint --concurrency=auto . && echo 'No lint violations.\n'",
    "lint:fix": "eslint --concurrency=auto --fix .",
    "duplication": "node scripts/run-parallel.ts duplication:src duplication:tests duplication:scripts duplication:e2e",
    "duplication:src": "printf 'Source ' && jscpd -s -c config/.jscpd.json",
    "duplication:tests": "printf 'Tests ' && jscpd -s -c config/.jscpd-tests.json",
    "duplication:scripts": "printf 'Scripts ' && jscpd -s -c config/.jscpd-scripts.json",
    "duplication:e2e": "printf 'E2E ' && jscpd -s -c config/.jscpd-e2e.json",
    "duplication:verbose": "jscpd -c config/.jscpd.json && jscpd -c config/.jscpd-tests.json && jscpd -c config/.jscpd-scripts.json && jscpd -c config/.jscpd-e2e.json",
    "loc": "node scripts/loc/loc.ts",
    "tc": "npm run typecheck",
    "typecheck": "echo 'Typechecking...' && node scripts/run-parallel.ts typecheck:src typecheck:scripts typecheck:e2e && echo 'No typecheck violations.\n'",
    "typecheck:src": "tsc --project src/tsconfig.json",
    "typecheck:scripts": "tsc --project scripts/tsconfig.json",
    "typecheck:e2e": "tsc --project e2e/tests/tsconfig.json",
    "e2e:mcp": "vitest run -c config/vitest.e2e.config.ts",
    "e2e:mcp:watch": "vitest -c config/vitest.e2e.config.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^5.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.1",
    "@rollup/plugin-alias": "^6.0.0",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-replace": "^6.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/eslint-plugin": "^1.6.15",
    "chokidar-cli": "^3.0.0",
    "eslint": "^10.2.0",
    "eslint-import-resolver-alias": "^1.1.2",
    "eslint-import-resolver-node": "^0.3.10",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsdoc": "^62.9.0",
    "eslint-plugin-sonarjs": "^4.0.3",
    "eslint-plugin-unicorn": "^64.0.0",
    "jscpd": "^4.0.9",
    "peggy": "^5.1.0",
    "prettier": "^3.8.2",
    "rollup": "^4.60.2",
    "rollup-plugin-copy": "^3.5.0",
    "rollup-plugin-esbuild": "^6.2.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
